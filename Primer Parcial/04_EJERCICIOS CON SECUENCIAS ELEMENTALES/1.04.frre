/*Se dispone de una secuencia de números de socios, y se desea saber la cantidad de socios que están 
registrados.*/
ACCION ejercicio4 ES
    Ambiente
        sec:secuencia de entero
        v:entero
        cont:entero
    Proceso
        cont:= 0
        ARR(sec)
        AVZ(sec, v)
        MIENTRAS NFDS(sec) HACER
            cont:= cont + 1
            AVZ(sec, v)
        FIN_MIENTRAS
        ESCRIBIR("La cantidad de socios son:", cont)
        CERRAR(sec)
FIN_ACCION


