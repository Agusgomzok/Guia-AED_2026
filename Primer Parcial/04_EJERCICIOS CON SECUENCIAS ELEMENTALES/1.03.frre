/*Se dispone de una secuencia de caracteres y se desea obtener una secuencia de salida que resulte de copiar la 
secuencia de entrada, descartando el caracter "$". */
ACCION Ejercicio3 ES
    Ambiente
        sec, sal:secuencia de caracter
        v:caracter

    Proceso
        ARR(sal)
        CREAR(sal)
        MIENTRAS NFDS(sec) HACER
            SI (V <> "$") ENTONCES
                ESCRIBIR(sal,v)    
            FIN_SI
            AVZ(sec,v)
        FIN_MIENTRAS
        CERRAR(sec)
        CERRAR(sal)
